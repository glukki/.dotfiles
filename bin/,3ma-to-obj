#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
# -*- coding: utf-8 -*-
"""
3MA to OBJ converter

Converts 3D modeling app (.3ma) files — renamed to .json — into Wavefront OBJ format.

Usage:
    ,3ma_to_obj.py input.json              # writes to stdout
    ,3ma_to_obj.py input.json -o out.obj   # writes to file
    cat input.json | ,3ma_to_obj.py        # reads from stdin
"""

import argparse
import json
import sys


def convert(data: dict) -> str:
    """Convert parsed 3MA JSON data to OBJ format string."""
    lines = []
    meshes = data["meshes"]
    vertex_index = 0

    for msh_idx, mesh in enumerate(meshes):
        lines.append("\ng \n")
        precise_factor = mesh["preciseFactor"]
        prev_vertex_index = vertex_index

        positions = mesh["_positions"]
        for vtx in range(0, len(positions), 3):
            x =  positions[vtx]     / precise_factor
            y =  positions[vtx + 1] / precise_factor
            z = -positions[vtx + 2] / precise_factor
            lines.append(f"v {x} {y} {z}\n")
            vertex_index += 1

        offset = prev_vertex_index if msh_idx > 0 else 0
        lines.append(f"\ng name{msh_idx} \n")
        for face in mesh["facesUnivertsList"]:
            indices = " ".join(str(i + 1 + offset) for i in face["u"])
            lines.append(f"f {indices}\n")

    return "".join(lines)


def main():
    parser = argparse.ArgumentParser(
        description="Convert 3MA (renamed to .json) files to Wavefront OBJ format."
    )
    parser.add_argument(
        "infile",
        nargs="?",
        type=argparse.FileType("r", encoding="utf-8"),
        default=sys.stdin,
        metavar="INPUT",
        help="3MA JSON file to read (default: stdin)",
    )
    parser.add_argument(
        "-o", "--output",
        type=argparse.FileType("w", encoding="utf-8"),
        default=sys.stdout,
        metavar="OUTPUT",
        help="OBJ file to write (default: stdout)",
    )
    args = parser.parse_args()

    try:
        data = json.load(args.infile)
    except json.JSONDecodeError as e:
        print(f"error: invalid JSON — {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"error reading input: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if args.infile is not sys.stdin:
            args.infile.close()

    try:
        obj_text = convert(data)
        args.output.write(obj_text)
        args.output.flush()
    except KeyError as e:
        print(f"error: malformed 3MA file — missing key {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        if args.output is not sys.stdout:
            args.output.close()


if __name__ == "__main__":
    main()
